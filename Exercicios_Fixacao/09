"# ============================================\n",
"# 03 - Sequência Iterativa Não Linear\n",
"# ============================================\n",
"# Se n for par → n = n / 2\n",
"# Se n for ímpar → n = 5n + 1\n",
"# Parar ao atingir 1 ou limite\n",
"\n",
"n = int(input('Digite o valor inicial: '))\n",
"limite = int(input('Limite maximo: '))\n",
"\n",
"passos = 0\n",
"maior = n\n",
"\n",
"while n != 1 and n < limite:\n",
"    if n % 2 == 0:\n",
"        n = n // 2\n",
"    else:\n",
"        n = 5 * n + 1\n",
"\n",
"    if n > maior:\n",
"        maior = n\n",
"\n",
"    passos += 1\n",
"\n",
"print('Passos:', passos)\n",
"print('Maior valor atingido:', maior)\n"
   ]
